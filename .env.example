# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your-bot-token-here

# Your Telegram Chat ID
CHAT_ID=your-chat-id-here

# Cron schedule for update checks (default: daily at 18:00)
CRON_SCHEDULE=0 18 * * *

# Comma-separated list of container names to exclude from checks
EXCLUDE_CONTAINERS=

# Timezone
TZ=Europe/Berlin
